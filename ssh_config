Host *
    IgnoreUnknown AddKeysToAgent,UseKeychain
    UseKeychain yes
    AddKeysToAgent yes

Host github.com
    IdentityFile ~/.ssh/gh

Host feral
    HostName aura.feralhosting.com
    User swimmernick
    #RequestTTY yes
    #RemoteCommand /media/689d/swimmernick/.linuxbrew/bin/tmux new -A -s ssh
    IdentitiesOnly yes
    IdentityFile ~/.ssh/feral_rsa

Host feral-plain
    HostName aura.feralhosting.com
    User swimmernick
    IdentitiesOnly yes
    IdentityFile ~/.ssh/feral_rsa

Host nas
